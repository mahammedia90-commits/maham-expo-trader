# MAHAM EXPO — Merchant Admin Environment
# ALL data comes from Admin Backend API — NOT a separate database

# Admin Backend API (single source of truth)
ADMIN_API_URL=https://admin.mahamexpo.sa/api/trpc

# Database (SAME as Admin Backend — shared maham_expo)
DATABASE_URL=mysql://user:password@localhost:3306/maham_expo

# OAuth (uses Admin Backend's OAuth system)
OAUTH_SERVER_URL=https://admin.mahamexpo.sa
VITE_OAUTH_PORTAL_URL=https://admin.mahamexpo.sa

# JWT (SAME secret as Admin Backend)
JWT_SECRET=MUST_MATCH_ADMIN_BACKEND_JWT_SECRET

# Server
PORT=3004
NODE_ENV=production
